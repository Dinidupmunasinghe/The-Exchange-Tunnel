NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=soundcloud_exchange
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_SYNC_ALTER=false

JWT_SECRET=replace_with_long_secure_secret
JWT_EXPIRES_IN=7d

ENCRYPTION_SECRET=replace_with_32_char_secret_key____

# SoundCloud OAuth 2.1 (PKCE on the browser). Required for native api.soundcloud.com flows.
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret
# Optional overrides (defaults are SoundCloud production endpoints)
# SOUNDCLOUD_AUTHORIZE_URL=https://secure.soundcloud.com/authorize
# SOUNDCLOUD_TOKEN_URL=https://secure.soundcloud.com/oauth/token
# SOUNDCLOUD_API_BASE=https://api.soundcloud.com

# Legacy Meta Graph (optional fallback when no PKCE code exchange is used)
META_APP_ID=
META_APP_SECRET=
META_LOGIN_APP_ID=
META_LOGIN_APP_SECRET=
META_PAGES_APP_ID=
META_PAGES_APP_SECRET=
META_GRAPH_API_BASE=https://graph.facebook.com/v22.0

CORS_ORIGIN=http://localhost:5173

DAILY_EARN_LIMIT=500
LIKE_REWARD=5
COMMENT_REWARD=10
SHARE_REWARD=15
