NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=exchange_tunnel
DB_USER=root
DB_PASSWORD=your_mysql_password
# Set true for Railway/public MySQL proxies that require TLS
DB_SSL=false
# Optional; default true when DB_SSL=true. Set false only if your host requires it.
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SYNC_ALTER=false

JWT_SECRET=replace_with_long_secure_secret
JWT_EXPIRES_IN=7d

ENCRYPTION_SECRET=replace_with_32_char_secret_key____

# Same token as the bot used for the Telegram Login widget. Required for /auth/telegram, getChat, getChatMember.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Bot username without @ — used for deep-link login URL construction.
TELEGRAM_BOT_NAME=YourBotName
# Random secret you choose — passed as X-Telegram-Bot-Api-Secret-Token when calling setWebhook.
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
# Python executable for MTProto bridge (Telethon user-auth flow)
TELEGRAM_MTPROTO_PYTHON=python
# Optional: server-side MTProto app credentials to avoid sending apiId/apiHash from clients.
TELEGRAM_MTPROTO_API_ID=
TELEGRAM_MTPROTO_API_HASH=

CORS_ORIGIN=http://localhost:5173

DAILY_EARN_LIMIT=500
LIKE_REWARD=5
COMMENT_REWARD=10
SHARE_REWARD=15
