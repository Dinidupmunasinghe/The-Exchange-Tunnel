# Dev: use `/api` so Vite proxies to the backend (see vite.config). Plain HTTP: `http://localhost:5000/api`
VITE_API_BASE_URL=/api

# Preferred: SoundCloud OAuth 2.1 + PKCE (same Client ID as backend SOUNDCLOUD_CLIENT_ID).
# Register redirect URLs in the SoundCloud app (e.g. https://localhost:5173/login and https://localhost:5173/settings).
VITE_SOUNDCLOUD_CLIENT_ID=
# Optional: default is https://secure.soundcloud.com/authorize
# VITE_SOUNDCLOUD_AUTHORIZE_URL=

# Optional legacy: Meta login / Pages connect if SoundCloud client ID is not set
VITE_META_LOGIN_APP_ID=
VITE_META_PAGES_APP_ID=
VITE_META_APP_ID=
